# Copy this file to backend/.env and fill in real values for local dev.
# In production (Render), set these as actual environment variables in the
# dashboard instead of uploading a .env file — see SUPABASE_MIGRATION.md.

# --- Supabase -----------------------------------------------------------
# Dashboard → Project Settings → API
#   SUPABASE_URL              = "Project URL"
#   SUPABASE_SERVICE_ROLE_KEY = "service_role" secret key
# NEVER use the anon key here, and never put either of these in the
# frontend — this key bypasses Row Level Security entirely.
SUPABASE_URL=https://bsucvxhvshvrwouupbct.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin auth -----------------------------------------------------------
# Any long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Changing this invalidates every admin's current login session.
JWT_SECRET=
JWT_EXPIRES_HOURS=12

# --- QR codes ---------------------------------------------------------------
# The deployed frontend URL — QR codes encode {FRONTEND_BASE_URL}/event/{id}.
FRONTEND_BASE_URL=http://localhost:5173
